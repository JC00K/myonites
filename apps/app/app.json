{
  "expo": {
    "name": "Musclaris",
    "slug": "musclaris",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "musclaris",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.musclaris.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Musclaris uses your camera to analyze exercise form during graded workouts. Frames are processed on-device and never stored or transmitted."
      }
    },
    "android": {
      "package": "com.musclaris.app",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
